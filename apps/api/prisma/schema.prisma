  roleType       String? // 역할유형
  docRequired    Boolean  @default(false) // 서류관리대상여부
  subscriptionYn String   @default("미구독") // 구독여부
  createdAt      DateTime @default(now())

  @@map("party")
}

// 04_사용자목록
model PlatformUser {
  userId          String    @id
  partyId         String
  name            String
  role            String?
  phone           String?
  isActive        Boolean   @default(true)
