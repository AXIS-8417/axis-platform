  @@map("eul_gate_event")
}

// 병 게이트원장 (G05)
model ByeongGateEvent {
  eventId         String    @id
  eventDatetime   DateTime? // 사건일시
  siteId          String? // 현장ID
  eventType       String? // 사건유형
  gateId          String? // 게이트ID
  materialSource  String? // 자재출처
  quantity        Float? // 수량(조)
  performType     String? // 수행유형 (설치/해체/회수/보수)
  teamId          String? // 팀ID
  teamLeaderName  String? // 팀장명
  workerCount     Int? // 투입인원
  judgmentResult  String? // 판정결과 (사용가능/사용불가/수리대기)
  unusableReason  String? // 사용불가사유
  byeongReceived  Boolean   @default(false) // 병인수여부
  eulPayAmount    Int? // 을지급금액(원)
  storageLocation String? // 보관위치
  evidenceLink    String? // 증빙링크
  sealType        String? // 잠금유형
  sealStatus      String? // 잠금상태
  sealId          String? // 잠금ID
  memo            String? // 메모
  eventPartyId    String? // 사건주체 PARTY_ID
  holdPartyId     String? // 보유주체 PARTY_ID
  createdAt       DateTime  @default(now())

  @@map("byeong_gate_event")
}

