  firstInstallDate DateTime? // 최초설치일
  gateType         String? // 게이트유형 (홀딩도어/양개도어/기타)
  heightM          Float? // 높이(m)
  widthM           Float? // 길이(m)
  isSplit          Boolean   @default(false) // 분할조여부
  splitDesc        String? // 분할설명
  material         String? // 재질 (신재/고재)
  yangaeStructure  String? // 양개구조 (해당/해당없음)
  currentStatus    String    @default("사용중") // 현재상태(자동파생)
  discardReason    String? // 폐기사유
  note             String? // 비고
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())

  @@map("gate_master")
}

// 을 게이트원장 (G04)
model EulGateEvent {
  eventId        String    @id
  eventDatetime  DateTime? // 사건일시
  siteId         String? // 현장ID
  eventType      String? // 사건유형 (이동/직송/설치/해체/회수/보수/상태판정/폐기)
  gateId         String? // 게이트ID
  materialSource String? // 자재출처 (우리재고/게이트업체재고/현장직송/타현장전용)
  quantity       Float? // 수량(조)
  moveTarget     String? // 이동대상 (을/병/현장)
  costNature     String? // 비용성격 (비용청구있음/비용청구없음/자재소유전환)
  amount         Int? // 금액(원)
  teamId         String? // 수행팀ID
  evidenceLink   String? // 증빙링크
  byeongEventRef String? // 병사건ID참조
  sealType       String? // 잠금유형 (단독잠금/상호잠금/미수락잠금)
  sealStatus     String? // 잠금상태 (작성중/잠금완료)
  sealId         String? // 잠금ID (서버발급)
